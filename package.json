{
  "name": "formmuse",
  "version": "0.0.0",
  "private": true,
  "description": "Premium, ready-to-paste Form Templates for React applications.",
  "license": "MIT",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.15.1"
  },
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "serve": "serve out",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "node --import tsx scripts/check-format.mts --write",
    "format:check": "node --import tsx scripts/check-format.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "playwright test",
    "test:registry-install": "node --import tsx scripts/verify-registry-install.ts",
    "guides:build": "fumadocs-mdx",
    "static-data:build": "node --import tsx scripts/build-static-data.mts",
    "static-data:fixture": "node --import tsx scripts/build-static-data.mts --fixture",
    "registry:build": "node --import tsx scripts/build-registry.ts",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@fontsource-variable/mulish": "5.3.0",
    "@gsap/react": "2.1.2",
    "@hookform/resolvers": "5.4.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fumadocs-core": "16.11.5",
    "fumadocs-mdx": "15.2.0",
    "gsap": "3.15.0",
    "lucide-react": "1.25.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.82.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/mdx": "2.0.14",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "jsdom": "29.1.1",
    "linkinator": "7.6.1",
    "postcss": "8.5.20",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "serve": "14.2.6",
    "shadcn": "4.13.1",
    "shiki": "4.3.1",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
